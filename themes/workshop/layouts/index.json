{{- /* Search index — set output formats in hugo.toml: home = ["HTML","RSS","JSON"] */ -}}
[
{{- $pages := where site.RegularPages "Section" "in" (slice "posts" "series") -}}
{{- range $i, $p := $pages -}}
  {{- if $i }},{{ end }}
  {
    "title": {{ $p.Title | jsonify }},
    "summary": {{ ($p.Description | default $p.Summary) | plainify | jsonify }},
    "content": {{ $p.Plain | truncate 2000 | jsonify }},
    "permalink": {{ $p.RelPermalink | jsonify }},
    "section": {{ $p.Section | jsonify }},
    "date": {{ $p.Date.Format "02 Jan 2006" | upper | jsonify }},
    "tags": {{ $p.Params.tags | default slice | jsonify }}
  }
{{- end }}
]
